# ============================================
# KorIA Platform — Environment Variables
# ============================================
# Copie este arquivo para .env e preencha os valores

# ---- Database ----
DATABASE_URL=postgresql://user:password@localhost:5432/koria_db

# ---- API ----
API_PORT=3000
API_PREFIX=/api/v1
NODE_ENV=development

# ---- JWT ----
JWT_SECRET=your-super-secret-jwt-key-change-me
JWT_EXPIRES_IN=7d

# ---- Storage (S3 / Cloudflare R2) ----
S3_BUCKET=koria-uploads
S3_REGION=auto
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT=https://xxx.r2.cloudflarestorage.com

# ---- Redis ----
REDIS_URL=redis://localhost:6379

# ---- Stripe ----
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ---- Wise ----
WISE_API_KEY=
WISE_WEBHOOK_SECRET=

# ---- ClickUp (OAuth 2.0) ----
CLICKUP_CLIENT_ID=your_clickup_client_id
CLICKUP_CLIENT_SECRET=your_clickup_client_secret
CLICKUP_REDIRECT_URI=http://localhost:3000/api/v1/clickup/callback
CLICKUP_ACCESS_TOKEN=
CLICKUP_REFRESH_TOKEN=

# ---- N8N Webhook (OCR Agent) ----
N8N_WEBHOOK_URL=https://n8n.koriastudio.com/webhook/ocr-upload

# ---- Tenant (KorIA) ----
DEFAULT_TENANT_ID=a9081890-d60f-4d91-ab05-c1407302a4c9

# ---- Frontend URLs ----
VITE_API_URL=http://localhost:3000/api/v1
BRIEFING_FORM_URL=http://localhost:5173
DASHBOARD_URL=http://localhost:5174
UPLOAD_PORTAL_URL=http://localhost:5175

# ---- Production URLs (reference) ----
# BRIEFING_FORM_URL=https://briefing.koriastudio.com
# DASHBOARD_URL=https://dashboard.koriastudio.com
# UPLOAD_PORTAL_URL=https://upload.koriastudio.com
